NODE_ENV=development
MONGO_URI=mongodb+srv://username:password@url.mongodb.net/dev?retryWrites=true&w=majority
JWT_SECRET=your-secret-here #run openssl rand -base64 32 to generate
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30
PORT=5000 # optional, defaults to 5000

R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

ENABLE_EXTERNAL_DNS='true'